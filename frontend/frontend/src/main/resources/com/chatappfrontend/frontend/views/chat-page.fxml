<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.chatappfrontend.frontend.controller.ChatPageController" stylesheets="@../styles/main.css">
    <Pane fx:id="backgroundPane" styleClass="chat-background"/>

    <HBox>
        <VBox styleClass="icon-bar" prefWidth="60" alignment="TOP_CENTER" spacing="10">
            <padding><Insets top="20" bottom="20"/></padding>

            <Button fx:id="chatsIconButton" text="💬" styleClass="icon-button" onAction="#showConversations"/>
            <Button fx:id="settingsIconButton" text="⚙️" styleClass="icon-button" onAction="#showSettings"/>
            <Button fx:id="friendsIconButton" text="👥" styleClass="icon-button" onAction="#showFriends"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="⏻" styleClass="logout-button" onAction="#handleLogout"/>
        </VBox>

        <VBox fx:id="fixedPanel" styleClass="fixed-panel" prefWidth="300">
            <VBox fx:id="conversationsPanel" VBox.vgrow="ALWAYS">
                <padding><Insets top="15" left="10" right="10" bottom="10"/></padding>

                <Label text="Chats" styleClass="panel-title"/>

                <TextField fx:id="searchField" promptText="Search users..." styleClass="search-field"/>

                <ListView fx:id="conversationList" VBox.vgrow="ALWAYS" styleClass="conversation-list"/>
            </VBox>

            <VBox fx:id="settingsPanel" visible="false" managed="false" VBox.vgrow="ALWAYS">
                <padding><Insets top="15" left="10" right="10" bottom="10"/></padding>

                <Label text="Settings" styleClass="panel-title"/>

                <Button text="Change Password" styleClass="settings-button" onAction="#handleChangePassword"/>
                <Button text="Edit Profile" styleClass="settings-button" onAction="#handleEditProfile"/>
                <Button text="Upload Profile Picture" styleClass="settings-button" onAction="#handleProfilePicture"/>
            </VBox>

            <VBox fx:id="friendsPanel" visible="false" managed="false" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets top="15" left="10" right="10" bottom="10"/>
                </padding>

                <Label text="Friends" styleClass="panel-title"/>
                <Label text="Find Friends" styleClass="section-title"/>

                <TextField fx:id="friendSearchField" promptText="Search people..." styleClass="search-field"/>

                <ListView fx:id="searchResultsList" prefHeight="180" styleClass="conversation-list"/>

                <Separator/>

                <Label text="Friend Requests" styleClass="section-title"/>

                <ListView fx:id="friendRequestsList" prefHeight="150" styleClass="conversation-list"/>

                <Separator/>

                <Label text="My Friends" styleClass="section-title"/>

                <ListView fx:id="friendsList" VBox.vgrow="ALWAYS" styleClass="conversation-list"/>
            </VBox>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" styleClass="chat-area">
            <HBox fx:id="chatHeader" styleClass="chat-header" alignment="CENTER_LEFT" spacing="10">
                <padding><Insets top="10" bottom="10" left="15" right="15"/></padding>
                <Label fx:id="chatNameLabel" text="Select a conversation" styleClass="chat-name"/>
            </HBox>

            <Label fx:id="notificationLabel" styleClass="notification-label" visible="false" managed="false"/>

            <ScrollPane fx:id="messagesScrollPane" VBox.vgrow="ALWAYS" fitToWidth="true" styleClass="messages-scroll">
                <VBox fx:id="messagesContainer" styleClass="messages-container" spacing="8">
                    <padding><Insets top="10" bottom="10" left="15" right="15"/></padding>
                </VBox>
            </ScrollPane>

            <VBox fx:id="replyPreviewBox" visible="false" managed="false"/>

            <HBox fx:id="messageInputArea" styleClass="message-input-area" alignment="CENTER" spacing="10">
                <padding><Insets top="10" bottom="10" left="15" right="15"/></padding>
                <TextField fx:id="messageInput" promptText="Type a message..." HBox.hgrow="ALWAYS" styleClass="message-input"/>
                <Button text="Send" styleClass="primary-button" onAction="#handleSendMessage"/>
            </HBox>
        </VBox>
    </HBox>
</StackPane>