<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.chatappfrontend.frontend.controller.LoginController" stylesheets="@../styles/main.css">
    <center>
        <VBox alignment="CENTER" spacing="15">
            <padding>
                <Insets top="50" bottom="50" left="100" right="100"/>
            </padding>

            <Label text="BP-Chat" styleClass="app-title"/>
            <Label text="Welcome" styleClass="subtitle"/>

            <TextField fx:id="emailField" promptText="Email" maxWidth="350"/>
            <PasswordField fx:id="passwordField" promptText="Password" maxWidth="350"/>

            <Label fx:id="errorLabel" styleClass="error-label" visible="false" maxWidth="350"/>

            <Button fx:id="loginButton" text="Login" maxWidth="350" onAction="#handleLogin" styleClass="primary-button"/>

            <ProgressIndicator fx:id="loadingSpinner" visible="false" maxWidth="30"/>

            <Hyperlink text="Forgot password?" onAction="#handleForgotPassword"/>

            <Hyperlink text="Don't have an account? Register" onAction="#handleRegister"/>
        </VBox>
    </center>
</BorderPane>