<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.chatappfrontend.frontend.controller.ForgotPasswordController" stylesheets="@../styles/main.css">
    <center>
        <VBox alignment="CENTER" spacing="15">
            <padding>
                <Insets top="50" bottom="50" left="100" right="100"/>
            </padding>

            <Label text="BP-Chat" styleClass="app-title"/>
            <Label text="Welcome" styleClass="subtitle"/>

            <TextField fx:id="emailField" promptText="Email" maxWidth="350"/>
            <TextField fx:id="codeField" promptText="Code" maxWidth="350" visible="false" managed="false"/>
            <PasswordField fx:id="newPasswordField" promptText="New Password" maxWidth="350" visible="false" managed="false"/>
            <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password" maxWidth="350" visible="false" managed="false"/>

            <Label fx:id="errorLabel" styleClass="error-label" visible="false" maxWidth="350"/>

            <Button fx:id="sendCodeButton" text="Send code" maxWidth="350" onAction="#handleSendCode" styleClass="primary-button"/>

            <ProgressIndicator fx:id="loadingSpinner" visible="false" maxWidth="30" managed="false"/>

            <Hyperlink text="Turn back" onAction="#goLoginPage"/>
        </VBox>
    </center>
</BorderPane>